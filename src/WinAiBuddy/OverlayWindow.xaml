<Window x:Class="WinAiBuddy.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="900"
        Height="170"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid IsHitTestVisible="False">
        <Border Margin="8"
                Padding="22"
                CornerRadius="18"
                Background="#D9111111"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
            <TextBlock x:Name="MessageTextBlock"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Text="Waiting for advice..." />
        </Border>
    </Grid>
</Window>
