<Window x:Class="WinAiBuddy.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WinAiBuddy.Controls"
        Width="900"
        Height="170"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid x:Name="RootGrid"
          Background="Transparent"
          IsHitTestVisible="False">
        <Border x:Name="EditHintBorder"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="24,0,0,0"
                Padding="10,6"
                CornerRadius="10"
                Background="#DD111111"
                BorderBrush="#50FFFFFF"
                BorderThickness="1"
                Visibility="Collapsed">
            <TextBlock Foreground="White"
                       FontSize="12"
                       Text="Drag the overlay to position it. Click Lock Overlay when you're done." />
        </Border>

        <Border x:Name="OverlayBorder"
                Margin="8"
                Padding="22"
                CornerRadius="18"
                Background="#D9111111"
                BorderBrush="#33FFFFFF"
                BorderThickness="1"
                MouseLeftButtonDown="OverlayBorder_OnMouseLeftButtonDown">
            <controls:OutlinedTextBlock x:Name="MessageTextBlock"
                                        Foreground="White"
                                        FontSize="26"
                                        FontWeight="SemiBold"
                                        Stroke="#FF06131A"
                                        StrokeThickness="2.5"
                                        Text="Waiting for advice..." />
        </Border>
    </Grid>
</Window>
