<Window x:Class="WinAiBuddy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Win AI Buddy"
        Width="920"
        Height="900"
        MinWidth="720"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Closing="Window_OnClosing"
        StateChanged="Window_OnStateChanged">
    <Grid>
        <TabControl TabStripPlacement="Left" Margin="8" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="16,12" />
                    <Setter Property="FontSize" Value="15" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,4" />
                </Style>
            </TabControl.Resources>

            <!-- Dashboard -->
            <TabItem Header="🏠 Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <TextBlock FontSize="28" FontWeight="SemiBold" Text="Win AI Buddy" />
                        <TextBlock Margin="0,8,0,0" Foreground="#666" TextWrapping="Wrap">
                            Streams your mic and optional screen frames into Gemini Live, plays streamed audio back, and shows transcribed coaching in the overlay.
                        </TextBlock>

                        <TextBlock Margin="0,32,0,0" FontWeight="SemiBold" Text="Session Status" />
                        <TextBlock x:Name="SessionStateTextBlock" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#555" Text="Stopped" />

                        <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Application Status" />
                        <TextBlock x:Name="StatusTextBlock" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#555" Text="Ready. Add your Gemini API key, then start the live session." />

                        <TextBlock Margin="0,24,0,0" FontWeight="SemiBold" Text="Input transcription" />
                        <TextBlock x:Name="InputTranscriptTextBlock" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#555" Text="Nothing heard yet." />

                        <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Output transcription" />
                        <TextBlock x:Name="OutputTranscriptTextBlock" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#555" Text="No model response yet." />

                        <StackPanel Orientation="Horizontal" Margin="0,32,0,0">
                            <Button Width="140" Height="36" Margin="0,0,12,0" Click="StartLiveButton_OnClick" Content="Start Live" />
                            <Button Width="140" Height="36" Margin="0,0,12,0" Click="StopLiveButton_OnClick" Content="Stop Live" />
                            <Button Width="160" Height="36" Click="HideToTrayButton_OnClick" Content="Hide To Tray" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Connection -->
            <TabItem Header="🔑 Connection">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Gemini API key" />
                        <PasswordBox x:Name="ApiKeyPasswordBox" Grid.Row="0" Grid.Column="1" Margin="0,8" Height="32" VerticalContentAlignment="Center" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Live model" />
                        <TextBox x:Name="LiveModelTextBox" Grid.Row="1" Grid.Column="1" Margin="0,8" Height="32" VerticalContentAlignment="Center" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Top" Text="System prompt" />
                        <TextBox x:Name="SystemPromptTextBox" Grid.Row="2" Grid.Column="1" Margin="0,8" MinHeight="250" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                        <Button Grid.Row="3" Grid.Column="1" Width="120" Height="36" Margin="0,24,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="SaveButton_OnClick" Content="Save" />
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Audio & Capture -->
            <TabItem Header="🎤 Audio &amp; Capture">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Voice" />
                        <Grid Grid.Row="0" Grid.Column="1" Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="VoiceComboBox" Grid.Column="0" Height="32" DisplayMemberPath="DisplayName" SelectedValuePath="Name" />
                            <Button Grid.Column="1" Width="110" Height="32" Margin="12,0,0,0" Click="PreviewVoiceButton_OnClick" Content="Preview" />
                            <Button Grid.Column="2" Width="90" Height="32" Margin="12,0,0,0" Click="StopPreviewButton_OnClick" Content="Stop" />
                        </Grid>
                        
                        <TextBlock x:Name="VoicePreviewStatusTextBlock" Grid.Row="1" Grid.Column="1" Margin="0,0,0,24" TextWrapping="Wrap" Foreground="#555" Text="Preview a local WAV sample for the selected voice." />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Microphone input" />
                        <ComboBox x:Name="MicrophoneComboBox"
                                  Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,8"
                                  Height="32"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="DeviceName" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Screen source" />
                        <ComboBox x:Name="ScreenSourceComboBox"
                                  Grid.Row="3"
                                  Grid.Column="1"
                                  Margin="0,8"
                                  Height="32"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="DeviceName" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Screen frame ms" />
                        <TextBox x:Name="ScreenIntervalTextBox" Grid.Row="4" Grid.Column="1" Margin="0,8" Height="32" VerticalContentAlignment="Center" />

                        <CheckBox x:Name="StreamScreenFramesCheckBox" Grid.Row="5" Grid.Column="1" Margin="0,16,0,0" Content="Stream screen frames continuously" />

                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,32,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <Button Width="140" Height="36" Margin="0,0,12,0" Click="RefreshSourcesButton_OnClick" Content="Refresh Sources" />
                            <Button Width="120" Height="36" Click="SaveButton_OnClick" Content="Save" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Overlay -->
            <TabItem Header="📺 Overlay">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,24" Foreground="#555" Text="Use hex colors like #FFFFFF or #FF00FF00. Adjust Overlay opens a draggable preview." />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Overlay seconds" />
                        <TextBox x:Name="OverlaySecondsTextBox" Grid.Row="1" Grid.Column="1" Margin="0,8" Height="32" VerticalContentAlignment="Center" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Overall text opacity" />
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="OverlayOpacitySlider" Grid.Column="0" Minimum="0.0" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="False" ValueChanged="OverlayOpacitySlider_OnValueChanged" />
                            <TextBlock x:Name="OverlayOpacityValueTextBlock" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.94" />
                        </Grid>

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Background opacity" />
                        <Grid Grid.Row="3" Grid.Column="1" Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="OverlayBgOpacitySlider" Grid.Column="0" Minimum="0.0" Maximum="1.0" TickFrequency="0.05" IsSnapToTickEnabled="False" ValueChanged="OverlayBgOpacitySlider_OnValueChanged" />
                            <TextBlock x:Name="OverlayBgOpacityValueTextBlock" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" Text="0.85" />
                        </Grid>

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Background color" />
                        <Grid Grid.Row="4" Grid.Column="1" Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OverlayBgColorTextBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center" TextChanged="OverlayPropertyTextBox_OnTextChanged" />
                            <Button Grid.Column="1" Width="80" Height="32" Margin="12,0,0,0" Content="Pick..." Click="PickBgColorButton_OnClick" />
                        </Grid>

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Text color" />
                        <Grid Grid.Row="5" Grid.Column="1" Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OverlayTextColorTextBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center" TextChanged="OverlayPropertyTextBox_OnTextChanged" />
                            <Button Grid.Column="1" Width="80" Height="32" Margin="12,0,0,0" Content="Pick..." Click="PickTextColorButton_OnClick" />
                        </Grid>

                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Font size" />
                        <Grid Grid.Row="6" Grid.Column="1" Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OverlayFontSizeTextBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center" TextChanged="OverlayPropertyTextBox_OnTextChanged" />
                            <Grid Grid.Column="1" Margin="12,0,0,0" Width="80" Height="32">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <RepeatButton Grid.Row="0" Content="▲" FontSize="8" Click="FontSizeUpButton_OnClick" Delay="250" Interval="50" IsTabStop="False" />
                                <RepeatButton Grid.Row="1" Content="▼" FontSize="8" Click="FontSizeDownButton_OnClick" Delay="250" Interval="50" IsTabStop="False" />
                            </Grid>
                        </Grid>

                        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Outline color" />
                        <Grid Grid.Row="7" Grid.Column="1" Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OverlayOutlineColorTextBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center" TextChanged="OverlayPropertyTextBox_OnTextChanged" />
                            <Button Grid.Column="1" Width="80" Height="32" Margin="12,0,0,0" Content="Pick..." Click="PickOutlineColorButton_OnClick" />
                        </Grid>

                        <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,8,16,8" VerticalAlignment="Center" Text="Outline thickness" />
                        <Grid Grid.Row="8" Grid.Column="1" Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OverlayOutlineThicknessTextBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center" TextChanged="OverlayPropertyTextBox_OnTextChanged" />
                            <Grid Grid.Column="1" Margin="12,0,0,0" Width="80" Height="32">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <RepeatButton Grid.Row="0" Content="▲" FontSize="8" Click="ThicknessUpButton_OnClick" Delay="250" Interval="50" IsTabStop="False" />
                                <RepeatButton Grid.Row="1" Content="▼" FontSize="8" Click="ThicknessDownButton_OnClick" Delay="250" Interval="50" IsTabStop="False" />
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,32,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Width="140" Height="36" Margin="0,0,12,0" Click="AdjustOverlayButton_OnClick" Content="Adjust Overlay" />
                                <Button Width="120" Height="36" Margin="0,0,12,0" Click="LockOverlayButton_OnClick" Content="Lock Overlay" />
                                <Button Width="140" Height="36" Margin="0,0,12,0" Click="ResetOverlayPositionButton_OnClick" Content="Reset Position" />
                                <Button Width="160" Height="36" Click="OverlayTestButton_OnClick" Content="Test Overlay" />
                            </StackPanel>
                            <Button Width="120" Height="36" HorizontalAlignment="Left" Click="SaveButton_OnClick" Content="Save" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- General -->
            <TabItem Header="⚙️ General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24">
                        <CheckBox x:Name="AutoStartSessionCheckBox" Margin="0,8,0,0" Content="Auto-start live session on launch" />
                        <CheckBox x:Name="StartMinimizedCheckBox" Margin="0,16,0,0" Content="Start minimized to tray" />
                        
                        <Button Width="120" Height="36" Margin="0,32,0,0" HorizontalAlignment="Left" Click="SaveButton_OnClick" Content="Save" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
